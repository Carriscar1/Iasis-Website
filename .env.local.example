# ─────────────────────────────────────────────
#  IASIS — Loja · variáveis de ambiente
#  Copie para ".env.local" e preencha. NUNCA comite o .env.local.
# ─────────────────────────────────────────────

# Mercado Pago (OPCIONAL). Vazio = MODO DEMONSTRAÇÃO (pagamento simulado,
# sem cobrança). Preencha com o Access Token (TEST-... ou APP_USR-...) para
# habilitar o pagamento real:
#   mercadopago.com.br → Seu negócio → Configurações → Credenciais.
MP_ACCESS_TOKEN=

# Supabase — chaves PÚBLICAS (seguras de expor). Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica

# Segredo interno que autoriza a emissão do código de ativação.
# Gere um valor aleatório e cadastre o MESMO valor no banco:
#   update public.app_secrets set value = '<este_valor>' where key = 'webhook_secret';
WEBHOOK_SECRET=troque_por_um_valor_aleatorio

# URL pública do site (em dev use http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Preço do dispenser, em reais (sem símbolo).
PRODUCT_PRICE=499
