# ─────────────────────────────────────────────
#  IASIS — Loja · variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha.
#  NUNCA comite o .env.local (já está no .gitignore).
# ─────────────────────────────────────────────

# Mercado Pago — pegue em: mercadopago.com.br → Seu negócio → Configurações
#   → Credenciais.  Comece com as credenciais de TESTE.
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Supabase — Settings → API.
#   URL é pública; a SERVICE ROLE KEY é secreta (só no servidor!).
SUPABASE_URL=https://qoqlsymvmmmsfsfscpmg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_a_service_role_key

# URL pública do site (em dev use http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Preço do dispenser, em reais (sem símbolo).
PRODUCT_PRICE=499
